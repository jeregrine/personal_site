<!DOCTYPE html>
<html lang="en">
  <head>
    <% title = if assigns[:title], do: assigns[:title], else: @name  %>
    <title><%= title %> </title>

    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="description" content="Jason Stiebs Personal Website" />
    <meta name="google-site-verification" content="HQWQG0ZG1ehtqg8ivSqHW1lZJks6yokHUEiXz8a1mnw" />
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <style>
        :root { --white: #F2F2F2; --black: #0D0C08; --light-grey: #BFBFBF; --grey: #737373; --dark-grey: #404040; }

        * { margin:0; padding:0; box-sizing:border-box; text-decoration:none; color: var(--black); background-color: var(--white); }
        body { padding:2rem;font-family:serif;font-size:16px } 
        a { text-decoration: none; -webkit-text-decoration-skip: objects; }
        a:before { content: "["; color: var(--light-grey); } 
        a:after { content: "]"; color: var(--light-grey); } 
        a:hover { background-color: var(--dark-grey); color: var(--white); }
        svg { display: inline; }
        article, header, nav, section, main { display: block; }
        html, body, div, article, section, main, footer, header, form, fieldset, legend,
        pre, code, a, h1, h2, h3, h4, h5, h6, p, ul, ol, li, dl, dt, dd, textarea, table,
        td, th, tr, input[type="email"], input[type="number"], input[type="password"],
        input[type="tel"], input[type="text"], input[type="url"], .border-box { box-sizing: border-box; }
        ul { list-style: none }

        header, footer { display: flex; flex-direction: row; width: 100%; align-content: flex-start; margin-bottom: 1rem;}
        footer { margin-top: 1rem; padding-top: 1rem; border-top: 2px solid var(--dark-grey); }
        header h1 { margin-right: 1rem; }

        footer ul li { display: inline; }
        footer ul li:last-child { margin-left: 1rem; }
        main { margin-top: 2rem; margin-bottom: 2rem;}

        article h2 { margin-bottom: 1rem; }

    </style>
  </head>
  <body>
    <header>
      <div><h1>JS</h1></div>
      <div> 
        <ul> 
          <li><a href="/now.html">now</a></li>
          <li> 
            <a href="https://www.rokkincat.com">company <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewbox="0 0 100 100">
                <g fill="#0DOCO8" fill-rule="nonzero">
                  <path d="M0 50v50h100V0H0v50zm95.522 0v45.5H4.478v-91h91.044V50z"/>
                  <path d="M18.01 32.35l.15 14.4h7.96l.15-4.4.148-4.35h1.443c1.294 0 1.84.55 4.478 4.5l3.035 4.5H39.8c2.49 0 4.48-.2 4.48-.4 0-.25-1.345-2.35-2.986-4.75-1.642-2.35-2.986-4.4-2.986-4.55 0-.2.995-1.25 2.19-2.45 4.875-4.7 3.98-12.4-1.84-15.45-1.892-1.05-2.887-1.15-11.444-1.3l-9.304-.2.1 14.45zm16.27-6.15c1.242 1.15 1.342 3.15.198 4.4-.647.7-1.543.9-4.478.9h-3.632v-6.6l3.433.2c2.49.1 3.732.45 4.48 1.1zM53.98 19.15c-.15.35-.2 6.8-.15 14.35l.15 13.75 4.13.15 4.08.15V43.6c0-3.65.1-4 1.392-5.25L64.975 37l3.483 5.1 3.433 5.15 4.876.15c2.637.05 4.826 0 4.826-.15s-2.488-3.9-5.522-8.25l-5.473-8 5.224-5.9c2.936-3.3 5.275-6.1 5.275-6.3 0-.15-2.09-.3-4.627-.3H71.79l-4.676 5.6-4.676 5.6-.15-5.6-.15-5.6h-3.98c-2.735 0-4.03.2-4.178.65zM18.26 53.35c-.2.15-.35 6.7-.35 14.5V82h8.458v-3.9c0-3.6.1-4 1.393-5.2l1.344-1.3 3.483 5.2L36.07 82h4.875c3.78 0 4.826-.15 4.528-.65-.2-.3-2.538-3.75-5.174-7.6-2.638-3.85-4.977-7.3-5.176-7.65-.248-.4 1.393-2.65 4.876-6.6 2.886-3.25 5.274-6.05 5.274-6.2 0-.15-2.09-.3-4.677-.3H35.92l-4.626 5.5-4.677 5.5-.15-5.5-.15-5.5h-3.88c-2.138 0-4.03.15-4.178.35zM54.23 67.5V82h7.96v-7.55c0-6.15.1-7.45.646-7.05.348.3 3.084 3.7 6.07 7.55L74.377 82h7.214V52.95l-4.08.15-4.13.15v7.1c0 3.95-.098 7.15-.248 7.1-.15 0-2.736-3.2-5.72-7.1l-5.474-7.1-3.88-.15-3.83-.15V67.5z"/>
                </g>
              </svg></a>
            </li>
        </ul>
    </header>

    <main>
      <%= @body %>
    </main>
    <footer> 
      <ul>
        <li><a href="https://git.sr.ht/~jeregrine/">git</a></li>
        <li><a href="https://twitter.com/peregrine">twitter</a></li>
        <li><a rel="me" href="https://merveilles.town/@peregrine">merveilles</a></li>
        <li><a target="_blank" href="mailto:jason.stiebs@hey.com?subject=hey">email</a></li>
        <li>Jason Stiebs © 2021</li>
      </ul>
    </footer>
  </body>
</html>
